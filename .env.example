# Register an app at https://dev.twitch.tv/console/apps
# Server-side only — never expose the secret in the browser.
TWITCH_CLIENT_ID=your_client_id_here
TWITCH_CLIENT_SECRET=your_client_secret_here
PORT=3000

# OAuth redirect must match exactly one of your Twitch app "OAuth Redirect URLs".
# Default server is HTTPS — use https://127.0.0.1:PORT/auth/callback in Twitch (see startup log).
# TWITCH_REDIRECT_URI=https://127.0.0.1:3000/auth/callback

# Plain HTTP only (no cert warning). OAuth redirect URLs in Twitch must use http:// then.
# USE_HTTP=true

# Trusted local HTTPS: run mkcert-local.bat (creates certs/localhost*.pem). The server
# auto-loads key+cert from certs/ OR cert/ with names localhost-key.pem + localhost.pem
# (or .key + .crt). Or set custom paths:
# HTTPS_KEY_PATH=certs/localhost-key.pem
# HTTPS_CERT_PATH=certs/localhost.pem
# Without mkcert files, the server uses a built-in self-signed cert ("Not secure").

# Twitch video: if streamlink is available (https://streamlink.github.io/) + ffmpeg, channels
# play as same-origin HLS (reliable muted autoplay). Otherwise the official iframe embed is used.
# TWITCH_PLAYBACK=iframe
# If pip installed streamlink but Windows PATH is wrong, set the full path to streamlink.exe:
# STREAMLINK_PATH=C:\Users\You\AppData\Roaming\Python\Python312\Scripts\streamlink.exe

# Twitch HLS (streamlink + ffmpeg): each live tile runs ffmpeg re-encode — heavy CPU with many
# streams. Defaults favor lower CPU (720p source, ultrafast x264, longer segments). Override:
# TWITCH_STREAMLINK_QUALITY=best
# TWITCH_FFMPEG_PRESET=ultrafast
# TWITCH_FFMPEG_MAX_HEIGHT=720
# TWITCH_FFMPEG_NO_SCALE=1
# TWITCH_HLS_TIME=4

# Used to sign the login cookie (any long random string).
# SESSION_SECRET=

# Where login session JSON files are stored. On Windows the default is under LOCALAPPDATA
# (avoids OneDrive/EPERM in the project folder). Override if needed:
# SESSION_FILE_PATH=C:\path\to\sessions

# Transcoded HLS (transcode:… URLs) — lower resolution / CPU (optional).
# FFMPEG_MAX_HEIGHT=480
# FFMPEG_PRESET=fast
