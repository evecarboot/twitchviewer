# Register an app at https://dev.twitch.tv/console/apps
# Server-side only — never expose the secret in the browser.
TWITCH_CLIENT_ID=your_client_id_here
TWITCH_CLIENT_SECRET=your_client_secret_here
PORT=3000

# OAuth redirect must match exactly one of your Twitch app "OAuth Redirect URLs".
# Default: https:// + host from your browser (see server startup log).
# TWITCH_REDIRECT_URI=https://127.0.0.1:3000/auth/callback

# Set to true to use plain HTTP only (OAuth URLs in Twitch must use http:// then).
# USE_HTTP=true

# Used to sign the login cookie (any long random string).
# SESSION_SECRET=

# Transcoded HLS (transcode:… URLs) — lower resolution / CPU (optional).
# FFMPEG_MAX_HEIGHT=480
# FFMPEG_PRESET=fast
